# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# 虚拟环境
.venv/
venv/
env/
ENV/

# ── 运行时 / 用户数据(全部收纳在 data/,整目录不入库)──────────────
# memory*.json/.md(每只宝可梦各一份)、conversation*.jsonl、scheduled_tasks.json、
# config_overrides.json、call_log.jsonl、danger_ops.jsonl、tool_events.jsonl、
# guardian_*、pet_settings.json、mcp_config.json、.web_console_token、.onboarded、
# .watchdog_pids、.chat_uploads_*/、各类 .lock / .*.tmp 残留——都落在 data/ 下。
# 整目录忽略,新增宝可梦的 memory_<名>.json 自动覆盖,无需逐个补规则。
data/

# ── 兼容老布局(数据曾散在项目根;config.py 启动会自动迁移到 data/,这里兜底)──
scheduled_tasks.json
scheduled_tasks.json.lock
scheduled_tasks.json.*.tmp
tool_events.jsonl
mcp_config.json
mcp_config.json.*.tmp
pet_settings.json
pet_settings.json.*.tmp
guardian_pending.jsonl
guardian_decision.*
danger_ops.jsonl
call_log.jsonl
call_log.jsonl.*.tmp
.watchdog_pids
.chat_uploads_*/
.onboarded
config_overrides.json
config_overrides.json.*.tmp
.web_console_token
# 记忆碎片(皮卡丘固定名 + 其余宝可梦 memory_<名>.* 通配)
memory.json
memory.md
memory.json.lock
memory_*.json
memory_*.md
memory_*.json.lock
memory*.json.*.tmp
memory*.md.*.tmp
conversation.jsonl
conversation_*.jsonl
conversation*.jsonl.lock
conversation*.jsonl.*.tmp

# ── 编辑器 / IDE ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── macOS ───────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# ── 日志 ────────────────────────────────────────────────
*.log
