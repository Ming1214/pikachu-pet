# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# 虚拟环境
.venv/
venv/
env/
ENV/

# ── 运行时自动生成的文件(不该进版本库)────────────────
# 用户的定时任务数据,运行时增删
scheduled_tasks.json
# MCP 工具事件流,运行时持续追加
tool_events.jsonl
# claude_bridge._ensure_mcp_config() 自动生成
mcp_config.json
# 锁文件 / 原子写残留临时文件
scheduled_tasks.json.lock
scheduled_tasks.json.*.tmp
# 看门狗:本会话 claude 子进程 pid 登记(退出清理用)
.watchdog_pids
# 首次引导标记
.onboarded
# 记忆碎片(用户数据):记忆库 + 自动导出的 md + 对话流水。退出保留、不入库。
memory.json
memory.md
conversation.jsonl
# 记忆相关的锁 / 原子写残留临时文件
memory.json.lock
memory.json.*.tmp
memory.md.*.tmp
conversation.jsonl.lock
conversation.jsonl.*.tmp

# ── 编辑器 / IDE ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── macOS ───────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# ── 日志 ────────────────────────────────────────────────
*.log
